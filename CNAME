<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>System MAX - Ultimate HUD Edition</title>

<style>
:root {
    --primary: #00e5ff;
    --primary-glow: rgba(0, 229, 255, 0.4);
    --bg-dark: #01080a;
    --warning: #ffaa00;
    --danger: #ff2a2a;
}

*{box-sizing: border-box;}
body{
    margin:0;
    background: var(--bg-dark);
    color: var(--primary);
    font-family: 'Courier New', monospace, sans-serif;
    overflow: hidden;
    height: 100vh;
    transition: background 0.5s ease;
}

/* ================== HIỆU ỨNG NỀN ĐA TẦNG ================== */
canvas#matrix {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    opacity: 0.12; z-index: 1; pointer-events: none; 
}

.grid-bg {
    position: fixed; top: -50%; left: -50%; width: 200%; height: 200%;
    background-image: 
        linear-gradient(rgba(0, 229, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 229, 255, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    transform: perspective(600px) rotateX(60deg) translateY(0);
    animation: gridMove 30s linear infinite;
    z-index: 2;
    pointer-events: none;
}
@keyframes gridMove {
    0% { transform: perspective(600px) rotateX(60deg) translateY(0); }
    100% { transform: perspective(600px) rotateX(60deg) translateY(600px); }
}

.hud-center-circles {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    border: 1px solid rgba(0, 229, 255, 0.1);
    border-radius: 50%;
    z-index: 3; pointer-events: none;
}
.hud-center-circles::before, .hud-center-circles::after {
    content: ''; position: absolute; border-radius: 50%;
}
.hud-center-circles::before {
    top: 10%; left: 10%; width: 80%; height: 80%;
    border: 2px dashed rgba(0, 229, 255, 0.15);
    animation: spinClockwise 20s linear infinite;
}
.hud-center-circles::after {
    top: 20%; left: 20%; width: 60%; height: 60%;
    border: 1px solid rgba(0, 229, 255, 0.05);
    border-top: 2px solid var(--primary);
    animation: spinCounter 10s linear infinite;
}
@keyframes spinClockwise { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes spinCounter { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }

.overlay-lines {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(rgba(1, 8, 10, 0) 50%, rgba(0, 0, 0, 0.4) 50%);
    background-size: 100% 4px;
    pointer-events: none; z-index: 5; 
}

/* ================== HIỆU ỨNG INTRO ================== */
#intro-scene {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: #000; z-index: 1000;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    transition: all 1.2s cubic-bezier(0.7, 0, 0.3, 1);
}
.cyber-ring {
    width: 140px; height: 140px;
    border: 2px solid transparent; border-top: 3px solid var(--primary); border-bottom: 3px solid var(--primary);
    border-radius: 50%; margin-bottom: 40px;
    animation: spinClockwise 1.5s cubic-bezier(0.53, 0.21, 0.29, 0.87) infinite;
    filter: drop-shadow(0 0 10px var(--primary-glow));
}
.glitch-text {
    font-size: 14px; letter-spacing: 8px; color: var(--primary);
    text-shadow: 0 0 10px var(--primary); font-weight: bold; text-transform: uppercase;
}

/* ================== BỐ CỤC CHÍNH ================== */
.main-content {
    opacity: 0; transform: scale(1.1); 
    transition: all 1.5s cubic-bezier(0.1, 1, 0.1, 1);
    display: flex; justify-content: center; align-items: center;
    width: 100%; height: 100vh; z-index: 10; position: relative;
}

.container {
    max-width: 450px; width: 92%;
    background: rgba(1, 12, 15, 0.85);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 229, 255, 0.3);
    padding: 35px 25px; text-align: center;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.6), inset 0 0 20px rgba(0, 229, 255, 0.05);
    position: relative;
    clip-path: polygon(0 40px, 40px 0, 100% 0, 100% calc(100% - 40px), calc(100% - 40px) 100%, 0 100%);
    z-index: 20; 
}
.container::before {
    content: 'SYSTEM SECURE'; position: absolute; top: 12px; left: 50px;
    font-size: 9px; color: rgba(0, 229, 255, 0.4); letter-spacing: 2px;
}

.corner-target { position: absolute; width: 25px; height: 25px; border: 2px solid var(--primary); opacity: 0.6; }
.tl { top: 0; left: 0; border-right: none; border-bottom: none; border-top-left-radius: 4px; }
.tr { top: 0; right: 0; border-left: none; border-bottom: none; border-top-right-radius: 4px;}
.bl { bottom: 0; left: 0; border-right: none; border-top: none; border-bottom-left-radius: 4px;}
.br { bottom: 0; right: 0; border-left: none; border-top: none; border-bottom-right-radius: 4px;}

h2 {
    color: var(--primary); font-size: 22px; letter-spacing: 6px;
    text-shadow: 0 0 15px var(--primary-glow); margin: 15px 0 25px 0;
    text-transform: uppercase; font-weight: 900;
}

.hud-data {
    display: flex; justify-content: space-between;
    font-size: 11px; color: var(--primary); opacity: 0.8;
    margin-bottom: 20px; border-bottom: 1px solid rgba(0, 229, 255, 0.15);
    padding-bottom: 10px;
}

.input-group { position: relative; margin-bottom: 15px; text-align: left; }
.input-label { font-size: 9px; color: rgba(0, 229, 255, 0.6); letter-spacing: 1px; margin-left: 5px; text-transform: uppercase; }

input, select {
    width: 100%; padding: 15px; margin: 5px 0 0 0;
    background: rgba(0, 20, 25, 0.6);
    color: var(--primary); border: 1px solid rgba(0, 229, 255, 0.2);
    font-family: 'Courier New', monospace; font-weight: bold;
    border-radius: 4px; transition: all 0.3s ease;
}
input:focus, select:focus {
    border-color: var(--warning); outline: none;
    box-shadow: 0 0 15px rgba(255, 170, 0, 0.15); color: var(--warning);
    background: rgba(0, 20, 25, 0.9);
}

button {
    width: 100%; padding: 18px; margin-top: 15px;
    background: transparent; color: var(--primary);
    border: 1px solid var(--primary);
    font-weight: bold; cursor: pointer;
    font-family: 'Courier New', monospace; font-size: 14px;
    letter-spacing: 4px; text-transform: uppercase;
    transition: all 0.3s ease; position: relative;
    overflow: hidden;
}
button:hover {
    background: rgba(0, 229, 255, 0.1);
    box-shadow: 0 0 20px var(--primary-glow);
    text-shadow: 0 0 8px var(--primary);
}
button:active { transform: scale(0.98); }
button:disabled { border-color: #22353a; color: #354e54; cursor: not-allowed; background: none; box-shadow: none; text-shadow: none;}

.binary-scanner {
    width: 100%; height: 35px;
    background: rgba(0, 10, 12, 0.8);
    border: 1px solid rgba(0, 229, 255, 0.15);
    margin: 15px 0; display: flex; justify-content: center; align-items: center;
}
.binary-stream {
    font-size: 11px; color: var(--primary);
    letter-spacing: 2px; text-shadow: 0 0 5px var(--primary-glow);
    font-weight: bold;
}

/* ================== THANH TIẾN TRÌNH ĐIỆN ẢNH ================== */
.progress {
    height: 6px; background: rgba(0, 20, 25, 0.8); margin-top: 15px;
    border-radius: 3px; overflow: hidden;
    border: 1px solid rgba(0, 229, 255, 0.1);
}
.bar { 
    height: 100%; 
    width: 0; 
    background: linear-gradient(90deg, var(--primary) 70%, #fff 100%); 
    box-shadow: 0 0 15px var(--primary), 0 0 5px #fff; 
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
    position: relative;
    overflow: hidden;
}

/* Hiệu ứng tia sáng quét ngược cực ngầu */
.bar::after {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
    animation: scanLight 1.5s infinite;
}

@keyframes scanLight {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

.log {
    height: 90px; overflow: auto;
    background: rgba(0, 5, 6, 0.8); margin-top: 15px; padding: 12px;
    font-size: 10px; text-align: left;
    border: 1px solid rgba(0, 229, 255, 0.1); color: #88c9b2;
}

/* BANNER CẢNH BÁO NGUY HIỂM */
.danger-banner {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(220, 20, 20, 0.95); color: #fff;
    padding: 25px 45px; font-weight: 900; font-size: 18px;
    letter-spacing: 4px; z-index: 100;
    border: 2px solid #fff; box-shadow: 0 0 40px var(--danger);
    display: none; pointer-events: none;
    animation: pulseDanger 0.4s infinite alternate cubic-bezier(0.4, 0, 0.6, 1);
}
@keyframes pulseDanger {
    0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(1.05); opacity: 1; }
}

/* HỆ THỐNG ALERT CUSTOM */
.custom-alert {
    display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.85); justify-content: center; align-items: center; z-index: 2000;
}
.alert-box {
    background: #010a0c; border: 1px solid var(--danger);
    padding: 30px; text-align: center; max-width: 380px; width: 85%;
    box-shadow: 0 0 30px rgba(255, 42, 42, 0.2);
    clip-path: polygon(0 0, 100% 0, 100% 85%, 85% 100%, 0 100%);
}
#alert-message { font-size: 13px; color: #ffcccc; line-height: 1.6; margin-bottom: 25px; }

/* RUNG LẮC MÀN HÌNH */
.shake-effect {
    animation: screenShake 0.15s infinite alternate;
}
@keyframes screenShake {
    0% { transform: translate(2px, 1px) rotate(0deg); }
    100% { transform: translate(-1px, -2px) rotate(0.5deg); }
}

/* MÀN HÌNH ĐEN QUÉT VÀ XÓA MÃ */
.fullscreen-loader {
    display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(1, 8, 10, 0.96); justify-content: center; align-items: center; z-index: 1500;
    flex-direction: column;
}

.terminal-delete-box { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 400px; }

.deleting-spinner {
    width: 80px; height: 80px;
    border: 3px solid rgba(255, 42, 42, 0.1); border-top: 3px solid var(--danger); border-radius: 50%;
    animation: spinClockwise 1s linear infinite; margin-bottom: 20px;
    box-shadow: 0 0 20px rgba(255, 42, 42, 0.2);
}

.deleting-text {
    color: var(--danger); font-size: 14px; font-weight: bold; letter-spacing: 2px;
    text-shadow: 0 0 10px rgba(255, 42, 42, 0.4); margin-bottom: 15px;
}

.terminal-output {
    width: 100%; height: 110px; background: rgba(0, 0, 0, 0.7);
    border: 1px solid rgba(255, 42, 42, 0.3); padding: 10px;
    overflow: hidden; font-size: 11px; color: #ff8888; text-align: left; line-height: 1.5;
}

/* MỤC CHUYỂN ĐỔI CỔNG QUỐC TẾ */
.portal-switch-box {
    display: none; flex-direction: column; align-items: center; width: 100%; max-width: 440px;
    background: rgba(0, 10, 15, 0.9); border: 1px solid #00ff88; padding: 30px;
    box-shadow: 0 0 30px rgba(0, 255, 136, 0.2);
    clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%);
    animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.portal-title {
    color: #00ff88; font-size: 16px; font-weight: bold; letter-spacing: 4px;
    text-shadow: 0 0 10px rgba(0, 255, 136, 0.3); margin-bottom: 20px; text-transform: uppercase;
}

.portal-status-line {
    width: 100%; display: flex; justify-content: space-between; font-size: 12px;
    color: #88c9b2; margin-bottom: 10px; font-family: monospace;
}

.portal-actions {
    display: flex; flex-direction: column; gap: 15px; width: 100%; margin-top: 15px;
}
.portal-actions-row {
    display: flex; gap: 15px; width: 100%;
}

.btn-loading {
    display: inline-block; width: 14px; height: 14px;
    border: 2px solid rgba(0, 255, 136, 0.3); border-top: 2px solid #00ff88;
    border-radius: 50%; animation: spinClockwise 0.6s linear infinite;
    vertical-align: middle; margin-right: 8px;
}

@keyframes scaleIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

/* ================== LIVE FEED ================== */
.live-feed {
    position: fixed; bottom: 20px; right: 20px;
    background: rgba(1, 15, 20, 0.9);
    border: 1px solid rgba(0, 229, 255, 0.2);
    width: 280px; height: 130px;
