// ================== HÀM CHẠY PHÂN TÍCH CHÍNH (TỐI ƯU 10 GIÂY) ==================
function startAnalysis(){
    usageData = getLimitData(); 
    if (usageData.count >= MAX_USES) {
        showAlert("Thiết bị này đã cạn kiệt lượt dùng trong ngày. Vui lòng quay lại vào ngày mai!");
        return;
    }

    let user = document.getElementById("user").value.trim();
    let gameSelect = document.getElementById("game").value;
    let game = gameSelect;
    
    if (gameSelect === "khac") {
        game = document.getElementById("other-game-input").value.trim();
    }

    if (!user || !game) { showAlert("Lệnh thất bại. Hãy điền đầy đủ ID và chọn máy chủ!"); return; }
    if (user.length < 6) { showAlert("Mã tài khoản quá ngắn. Hệ thống yêu cầu tối thiểu 6 ký tự!"); return; }

    document.getElementById("btn").disabled = true;

    let bar = document.getElementById("bar");
    let p = 0;
    let logStatus = { ping: false, s1: false, s2: false, s3: false };

    startTimer();
    log(`[PING] Đang kiểm tra độ trễ đến cổng ${game}...`);
    
    // Đổi tốc độ lặp từ 120ms xuống 50ms để thanh chạy mượt và nhanh hơn
    let runInterval = setInterval(() => {
        let inc = 0;
        if (p < 5 && !logStatus.ping) {
            setTimeout(() => {
                let randomPing = Math.floor(Math.random() * 30) + 10;
                log(`[PING] Kết nối ổn định. Độ trễ: ${randomPing}ms.`);
                logStatus.ping = true;
            }, 800); 
            return; 
        }

        // Tự động tính toán tăng phần trăm để chạm đích 100% trong ~10 giây
        if (p < 55) inc = Math.random() * 1.2;
        else if (p >= 55 && p < 75) inc = Math.random() * 0.15; // Khựng lại cảnh báo nguy hiểm
        else if (p >= 75 && p < 100) inc = Math.random() * 1.5;

        p += inc; if (p > 100) p = 100;
        bar.style.width = p + "%";

        if (p > 10 && !logStatus.s1) { log("Khởi tạo đường truyền đến " + game + "..."); logStatus.s1 = true; }
        if (p > 30 && !logStatus.s2) { log("Thẩm định tài khoản: " + user); logStatus.s2 = true; }
        
        if (p > 55 && p < 75 && !logStatus.s3) {
            log("<span style='color:var(--danger);'>Nguy hiểm: Phát hiện tệp lệnh lạ (mã ẩn)!</span>");
            document.body.style.background = "#2a0202";
            document.getElementById("danger-banner").style.display = "block";
            soundAlarm.play().catch(()=>{});
            document.body.classList.add("shake-effect");
            isAlarming = true;
            logStatus.s3 = true;
        }

        if (p == 100) {
            clearInterval(runInterval);
            
            clearInterval(timerInterval);
            document.getElementById("timer").style.display = "none";

            document.body.style.background = "var(--bg-dark)";
            document.getElementById("danger-banner").style.display = "none";
            soundAlarm.pause(); soundAlarm.currentTime = 0;
            isAlarming = false; 

            let loader = document.getElementById("fullscreen-loader");
            loader.style.display = "flex";
            
            let delTime = 5;
            let delCountdownElem = document.getElementById("del-countdown");
            let terminalElem = document.getElementById("terminal-code");
            
            delCountdownElem.innerText = `ĐANG TIẾN HÀNH XÓA MÃ ẨN (${delTime}s)...`;

            let codeInterval = setInterval(() => {
                let randomCode = hackerScripts[Math.floor(Math.random() * hackerScripts.length)];
                terminalElem.innerHTML += randomCode + "<br>";
                terminalElem.scrollTop = terminalElem.scrollHeight;
                soundType.currentTime = 0; soundType.play().catch(()=>{});
            }, 250);

            let deleteInterval = setInterval(() => {
                delTime--;
                delCountdownElem.innerText = `ĐANG TIẾN HÀNH XÓA MÃ ẨN (${delTime}s)...`;
                
                if (delTime <= 0) {
                    clearInterval(deleteInterval);
                    clearInterval(codeInterval);
                    
                    document.getElementById("status-deleting").style.display = "none";
                    document.getElementById("portal-switch").style.display = "flex";
                    soundSuccess.play().catch(()=>{});
                    
                    document.body.classList.remove("shake-effect");
                    
                    usageData.count += 1;
                    localStorage.setItem("system_usage", JSON.stringify(usageData));
                    let rem = MAX_USES - usageData.count;
                    document.getElementById("limit-text").innerText = "LƯỢT QUÉT HÔM NAY: " + (rem < 0 ? 0 : rem) + "/" + MAX_USES;
                }
            }, 1000); 
        }
    }, 50); // Lặp nhanh hơn để tăng hiệu ứng dải sáng mượt mà
}

