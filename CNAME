<script>
// 0. MATRIX NỀN
let c=document.getElementById("matrix");
let ctx=c.getContext("2d");
c.width=innerWidth; c.height=innerHeight;
let letters="010101X", size=16, cols=c.width/size, drops=[];
for(let i=0; i<cols; i++) drops[i]=1;

setInterval(()=>{
    ctx.fillStyle="rgba(1, 8, 10, 0.08)"; ctx.fillRect(0, 0, c.width, c.height);
    ctx.fillStyle="#00e5ff"; ctx.font=size+"px monospace";
    for(let i=0; i<drops.length; i++){
        let text=letters[Math.random()*letters.length|0];
        ctx.fillText(text, i*size, drops[i]*size);
        if(drops[i]*size>c.height && Math.random()>0.975) drops[i]=0;
        drops[i]++;
    }
}, 40);

// 1. INTRO KHI VÀO TRANG
const introTextArr = ["HỆ THỐNG KHỞI TẠO...", "VƯỢT LỬA TƯỜNG QUỐC TẾ...", "SẴN SÀNG."];
let introIdx = 0;

function runIntro() {
    let textElem = document.getElementById('intro-text');
    let introInterval = setInterval(() => {
        if (introIdx < introTextArr.length) {
            textElem.innerText = introTextArr[introIdx];
            introIdx++;
        } else {
            clearInterval(introInterval);
            let introScn = document.getElementById('intro-scene');
            introScn.style.opacity = '0';
            
            setTimeout(() => {
                introScn.style.display = 'none';
                let mainContent = document.getElementById('main-content');
                mainContent.style.opacity = '1';
