    text-align: left;
}
.feed-header {
    color: var(--primary); font-weight: bold; letter-spacing: 1px;
    border-bottom: 1px solid rgba(0, 229, 255, 0.15);
    padding-bottom: 5px; margin-bottom: 5px; font-size: 9px;
}
.feed-content { color: #88c9b2; line-height: 1.6; }
.feed-content span { color: var(--warning); }
</style>
</head>

